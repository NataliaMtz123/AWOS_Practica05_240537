extends layout

block content
  main.dashboard-container
    .section-header
      h1
        i.bx.bxs-rocket
        span  Portal NASA
      p.student-info Ingrid Natalia - 240537

    section.search-section
      form(action="/dashboard/nasa" method="GET")
        label(for="date") 📅 Selecciona una fecha
        input(type="date" name="date" id="date" required)
        button(type="submit")
          i.bx.bx-search
          span  Explorar Fecha

    if apod
      section.apod-display
        .card-dynamic
          if apod.media_type === 'image'
            img(src=apod.url alt=apod.title)
          else if apod.media_type === 'video'
            iframe(src=apod.url frameborder="0" allowfullscreen)
          else
            p.source-note Tipo de media: #{apod.media_type}
          
          h2= apod.title
          p(style="margin-bottom: 15px;")= apod.explanation
          
          .card-dynamic(style="background: rgba(99, 102, 241, 0.1); border: none; padding: 20px; margin-top: 20px;")
            p
              strong Fecha:
              span(style="margin-left: 10px;")= apod.date
            if apod.media_type
              p(style="margin-top: 10px;")
                strong Tipo de media:
                span(style="margin-left: 10px;")= apod.media_type
            if apod.copyright
              p(style="margin-top: 10px;")
                strong Créditos:
                span(style="margin-left: 10px;")= apod.copyright
    else
      .card-dynamic(style="text-align: center; padding: 60px 30px;")
        i.bx.bx-loader-circle(style="font-size: 3rem; animation: spin 1s linear infinite;")
        p(style="margin-top: 15px; color: var(--muted-text);") Selecciona una fecha para ver la Imagen Astronómica del Día (APOD)