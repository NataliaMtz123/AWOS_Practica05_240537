extends layout

block content
  main.dashboard-container
    .section-header
      h1
        i.bx.bxs-football
        span  FIFA World Stats
      p.student-info Ingrid Natalia - 240537

    section.search-section
      form(action="/dashboard/fifa" method="GET" style="display: inline-flex; gap: 12px;")
        input(type="hidden" name="type" value="league")
        label(style="display: flex; align-items: center; gap: 8px;")
          i.bx.bxs-trophy
          span Búsqueda de Liga
        input(type="text" name="id" placeholder="ID Liga (Ej. 39)")
        button(type="submit")
          i.bx.bx-search
          span Buscar

      form(action="/dashboard/fifa" method="GET" style="display: inline-flex; gap: 12px; margin-left: 20px;")
        input(type="hidden" name="type" value="player")
        label(style="display: flex; align-items: center; gap: 8px;")
          i.bx.bxs-user
          span Búsqueda de Jugador
        input(type="text" name="search" placeholder="Nombre jugador (Ej. Messi)")
        button(type="submit")
          i.bx.bx-search
          span Filtrar

    if searchResults && searchResults.length > 0
      section(style="margin-bottom: 40px;")
        .card-dynamic(style="background: rgba(236, 72, 153, 0.1); border-color: #ec4899;")
          h2(style="color: #ec4899; display: flex; align-items: center; gap: 10px;")
            i.bx.bx-search-alt-2
            span Resultados: #{searchTerm}
          
          table(style="width: 100%; margin-top: 20px;")
            thead
              tr
                th Nombre
                th País / Equipo
                th Logo / Foto
            tbody
              each res in searchResults
                tr
                  if res.league
                    td= res.league.name
                    td= res.country.name
                    td: img(src=res.league.logo width="45" alt="league logo" style="border-radius: 4px;")
                  else if res.player
                    td= res.player.name
                    td= (res.statistics && res.statistics[0]) ? res.statistics[0].team.name : 'N/A'
                    td: img(src=res.player.photo width="45" style="border-radius: 50%;" alt="player photo")
                  else
                    td= res.name || 'N/A'
                    td= res.country || 'N/A'
                    td: img(src=res.logo width="45" alt="logo" style="border-radius: 4px;")

    section
      .card-dynamic(style="background: rgba(14, 184, 166, 0.1); border-color: #14b8a6;")
        h2(style="color: #14b8a6; display: flex; align-items: center; gap: 10px;")
          i.bx.bxs-trophy
          span Ligas Principales
        
        table(style="width: 100%; margin-top: 20px;")
          thead
            tr
              th ID
              th Logo
              th Liga
              th País
          tbody
            if leagues && leagues.length > 0
              each item in leagues
                tr
                  td(style="font-weight: 600;")= item.league.id
                  td: img(src=item.league.logo width="40" alt="logo" style="border-radius: 4px;")
                  td= item.league.name
                  td= item.country.name
            else
              tr
                td(colspan="4" style="text-align: center; padding: 30px; color: var(--muted-text);")
                  i.bx.bx-info-circle(style="display: block; font-size: 2rem; margin-bottom: 10px;")
                  span No hay datos disponibles