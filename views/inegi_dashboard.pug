extends layout

block content
  main.dashboard-container
    .section-header
      h1
        i.bx.bxs-bar-chart-alt-2
        span  Indicadores INEGI
      p.student-info Ingrid Natalia - 240537

    section.search-section
      form(action="/dashboard/inegi" method="GET")
        label(for="search") 🆔 Busca un indicador
        input(type="text" name="search" id="search" placeholder="Ej. 1002000001" required)
        button(type="submit")
          i.bx.bx-search
          span Consultar

    if indicator
      section
        .card-dynamic(style="background: rgba(132, 204, 22, 0.1); border-color: #84cc16;")
          h2(style="color: #84cc16; display: flex; align-items: center; gap: 10px;")
            i.bx.bx-check-circle
            span= indicator.nombre
          
          p(style="font-size: 1.3rem; font-weight: 700; margin: 15px 0; color: #84cc16;")= indicator.valor
          p(style="color: var(--muted-text); margin-bottom: 10px;")
            strong Fecha:
            span(style="margin-left: 10px;")= indicator.fecha

    section
      .chart-container(style="min-height: 450px;")
        canvas#inegiChart

block scripts
  script(src="/charts.js")