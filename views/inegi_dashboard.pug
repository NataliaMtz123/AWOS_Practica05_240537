extends layout

block content
  //- Reducimos drásticamente el padding superior
  main.dashboard-detail(style="padding-top: 5px; max-height: 95vh; overflow-y: auto;")
    
    //- Encabezado ultra-compacto
    header(style="margin-bottom: 10px; text-align: center;")
      h2(style="margin: 0; font-size: 1.4rem; color: #00d4ff;") 📊 Indicadores INEGI
      p(style="margin: 0; font-size: 0.85rem; opacity: 0.7;") Yazmin Ariana - 240235

    //- 🔍 BUSCADOR COMPACTO (Añadido para Fase 06)
    section.search-bar(style="margin-bottom: 10px; display: flex; justify-content: center;")
      form(action="/dashboard/inegi" method="GET" style="display: flex; gap: 8px; align-items: center; background: rgba(0,212,255,0.1); padding: 5px 15px; border-radius: 20px; border: 1px solid #00d4ff;")
        label(style="color: #fff; font-size: 0.8rem;") 🆔 ID:
        input(type="text" name="search" placeholder="Ej. 1002000001" style="background: transparent; color: #fff; border: none; border-bottom: 1px solid #00d4ff; font-size: 0.8rem; width: 100px; outline: none;")
        button(type="submit" style="background: #00d4ff; color: #000; border: none; border-radius: 12px; padding: 2px 10px; font-size: 0.75rem; font-weight: bold; cursor: pointer;") CONSULTAR

    //- 💡 CUADRO DE RESULTADO RÁPIDO
    if indicator
      section.result-box(style="text-align: center; margin-bottom: 10px; padding: 5px; background: rgba(0,0,0,0.4); border-radius: 8px; border-left: 4px solid #00d4ff;")
        span(style="color: #00d4ff; font-weight: bold; font-size: 0.9rem;") #{indicator.nombre}: 
        span(style="color: #fff; font-size: 1.1rem; margin-left: 10px;") #{indicator.valor} 
        small(style="color: #aaa; margin-left: 5px;") (#{indicator.fecha})

    //- Sección de la gráfica con más altura
    section.card-full(style="height: 60vh; padding: 10px; margin: 0 auto; max-width: 1000px; background: rgba(0,0,0,0.2); border-radius: 10px;")
      //- Contenedor ampliado a 450px para mejor visibilidad
      .chart-container(style="position: relative; height: 400px; width: 100%;")
        canvas#inegiChart
block scripts
  script(src="/charts.js")