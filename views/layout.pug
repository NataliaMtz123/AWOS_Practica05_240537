doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    meta(name="description", content="Portal de Datos - NASA, FIFA, INEGI")
    meta(name="theme-color", content="#6366f1")
    title= title || 'Portal de Datos - Dashboards'
    link(rel="stylesheet", href="/style.css")
    link(href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet')
    script(src="https://cdn.jsdelivr.net/npm/chart.js")
  body
    canvas#starCanvas
    .container
      header
        h1= title
        p.student-info
          i.bx.bxs-user
          span  = student
        nav
          a.btn(href="/")
            i.bx.bx-home-alt
            span  Inicio
      
      block content

    script(src="/stars.js")
    block scripts